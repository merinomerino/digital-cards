rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isValidSlug(s) {
      return s is string
        && s.size() >= 2
        && s.size() <= 80
        && s.matches('^[a-z0-9][a-z0-9-]*[a-z0-9]$');
    }

    function isValidCard() {
      let d = request.resource.data;
      return d.keys().hasAll(['slug', 'pinHash', 'nombre', 'tituloProfesional', 'createdAt', 'updatedAt'])
        && isValidSlug(d.slug)
        && d.pinHash is string && d.pinHash.size() == 64  // SHA-256 hex
        && d.nombre is string && d.nombre.size() > 0 && d.nombre.size() <= 100
        && d.tituloProfesional is string
        && d.createdAt is timestamp
        && d.updatedAt is timestamp;
    }

    match /cards/{cardId} {
      // Campos públicos — excluye pinHash de acceso directo desde cliente
      // (pinHash se valida únicamente server-side via API Route)
      allow read: if true;

      // Crear: validación estricta de campos
      allow create: if isValidCard();

      // Update: slug y pinHash son inmutables desde el cliente
      // La verificación real del PIN ocurre en la API Route del servidor
      allow update: if request.resource.data.slug == resource.data.slug
        && request.resource.data.pinHash == resource.data.pinHash;

      // Eliminar: solo admins autenticados vía Firebase Auth
      allow delete: if request.auth != null;
    }

    // Colección de usuarios (admins y clientes de CardLink)
    match /users/{userId} {
      // Solo usuarios autenticados pueden leer perfiles
      allow read: if request.auth != null;

      // Crear propio perfil al registrarse
      allow create: if request.auth != null && request.auth.uid == userId;

      // Actualizar propio perfil — NO se permite cambiar el campo role
      allow update: if request.auth != null
        && request.auth.uid == userId
        && (!('role' in request.resource.data) || request.resource.data.role == resource.data.role)
        && (!('active' in request.resource.data) || request.resource.data.active == resource.data.active);

      // Nunca se permite borrar desde cliente
      allow delete: if false;
    }

    // Bloquear cualquier otra colección
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
