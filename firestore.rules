rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isValidSlug(s) {
      return s is string
        && s.size() >= 2
        && s.size() <= 80
        && s.matches('^[a-z0-9][a-z0-9-]*[a-z0-9]$');
    }

    function isValidCard() {
      let d = request.resource.data;
      return d.keys().hasAll(['slug', 'pinHash', 'nombre', 'tituloProfesional', 'createdAt', 'updatedAt'])
        && isValidSlug(d.slug)
        && d.pinHash is string && d.pinHash.size() == 64  // SHA-256 hex
        && d.nombre is string && d.nombre.size() > 0 && d.nombre.size() <= 100
        && d.tituloProfesional is string
        && d.createdAt is timestamp
        && d.updatedAt is timestamp;
    }

    match /cards/{cardId} {
      // Cualquiera puede leer tarjetas (son públicas por diseño)
      allow read: if true;

      // Crear: validación estricta de campos
      allow create: if isValidCard();

      // Update: permitido (el PIN se verifica en la API Route del servidor)
      // Nunca se expone el endpoint de update directamente al cliente
      allow update: if request.resource.data.slug == resource.data.slug  // slug inmutable
        && request.resource.data.pinHash == resource.data.pinHash;        // PIN inmutable

      // Nunca se permite borrar
      allow delete: if false;
    }

    // Colección de usuarios (admins y clientes de CardLink)
    match /users/{userId} {
      // Cualquier usuario autenticado puede leer perfiles (admin panel necesita listar usuarios)
      allow read: if request.auth != null;
      // Solo el propio usuario puede crear/actualizar su documento (setup, registro)
      allow create, update: if request.auth != null && request.auth.uid == userId;
      // Nunca se permite borrar desde cliente
      allow delete: if false;
    }

    // Bloquear cualquier otra colección
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
