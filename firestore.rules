rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isValidSlug(s) {
      return s is string
        && s.size() >= 2
        && s.size() <= 80
        && s.matches('^[a-z0-9][a-z0-9-]*[a-z0-9]$');
    }

    function isValidCard() {
      let d = request.resource.data;
      return d.keys().hasAll(['slug', 'pinHash', 'nombre', 'tituloProfesional', 'createdAt', 'updatedAt'])
        && isValidSlug(d.slug)
        && d.pinHash is string && d.pinHash.size() == 64
        && d.nombre is string && d.nombre.size() > 0 && d.nombre.size() <= 100
        && d.tituloProfesional is string
        && d.createdAt is timestamp
        && d.updatedAt is timestamp;
    }

    match /cards/{cardId} {
      // Lectura pública de tarjetas (slug, nombre, diseño, etc.)
      // pinHash queda expuesto en lectura directa — el API Route lo filtra antes
      // de enviarlo al browser; Firestore SDK directo no debe usarse desde clientes no confiables.
      allow read: if true;

      // Crear: requiere autenticación + validación de campos.
      // El ownerId debe coincidir con el uid del usuario autenticado.
      allow create: if request.auth != null
        && isValidCard()
        && (!('ownerId' in request.resource.data) || request.resource.data.ownerId == request.auth.uid);

      // Update: slug y pinHash son inmutables desde el cliente.
      // Solo el propietario puede editar (si ownerId existe).
      // Tarjetas sin ownerId (legacy) pueden editarse con auth genérica temporalmente.
      allow update: if request.auth != null
        && request.resource.data.slug == resource.data.slug
        && request.resource.data.pinHash == resource.data.pinHash
        && (
          !('ownerId' in resource.data)
          || resource.data.ownerId == request.auth.uid
        );

      // Borrar: solo el propietario puede borrar su tarjeta.
      // Tarjetas legacy (sin ownerId) solo admins — se gestiona server-side.
      allow delete: if request.auth != null
        && (
          !('ownerId' in resource.data)
          || resource.data.ownerId == request.auth.uid
        );
    }

    match /users/{userId} {
      // Solo usuarios autenticados pueden leer perfiles
      allow read: if request.auth != null;

      // Crear propio perfil al registrarse.
      // CRÍTICO: role solo puede ser 'client' desde el cliente.
      // Los roles admin/root solo se asignan server-side.
      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.role == 'client';

      // Actualizar propio perfil — NO se permite cambiar role ni active desde cliente.
      allow update: if request.auth != null
        && request.auth.uid == userId
        && (!('role' in request.resource.data) || request.resource.data.role == resource.data.role)
        && (!('active' in request.resource.data) || request.resource.data.active == resource.data.active);

      // Nunca se permite borrar desde cliente
      allow delete: if false;
    }

    // Bloquear cualquier otra colección
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
