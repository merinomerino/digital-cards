rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /cards/{slug}/profile.{ext} {
      // Lectura pública (las URLs son públicas en la app)
      allow read: if true;

      // Escritura: solo usuarios autenticados, archivos de imagen, máx 5 MB
      allow write: if request.auth != null
        && request.resource != null
        && request.resource.size <= 5 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|png|webp|heic)');

      // Eliminar: solo el usuario autenticado (propietario de sesión activa)
      allow delete: if request.auth != null;
    }

    // Bloquear cualquier otra ruta de Storage
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
